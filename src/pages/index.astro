---
import Layout from '../layouts/Layout.astro';

const featuredPosts = [
  {
    title: 'Bygg en AI-strategi som faktiskt fungerar',
    href: '/artiklar/bygg-en-ai-strategi-som-fungerar',
    category: 'AI Transformation',
    excerpt: 'A practical framework for moving from AI experiments to operating model level impact.'
  },
  {
    title: 'Skalera Meta Ads utan att forstora ROAS',
    href: '/artiklar/skalera-meta-ads-utan-att-forstora-roas',
    category: 'Paid Social',
    excerpt: 'How to scale spend while protecting efficiency and keeping the funnel healthy.'
  },
  {
    title: 'Personalisering i stor skala med AI',
    href: '/artiklar/personalisering-i-stor-skala-med-ai',
    category: 'Marketing Automation',
    excerpt: 'Designing AI-assisted messaging systems that personalize without creating chaos.'
  }
];

const faqs = [
  {
    q: 'What size companies do you work with?',
    a: 'Most clients are growth-stage and mid-market teams, but the model also fits enterprise projects that need focused senior execution.'
  },
  {
    q: 'How quickly can we start?',
    a: 'Most projects can start within 1-2 weeks. First step is a 30-minute call to align on objective, scope, and timeline.'
  },
  {
    q: 'Do you work as advisor or hands-on partner?',
    a: 'Both. Engagements can be strategy only, execution only, or a hybrid model where strategy and implementation run in parallel.'
  },
  {
    q: 'Do you support in-house teams?',
    a: 'Yes. Many engagements include coaching and enablement so your team can run independently after the project.'
  }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a
    }
  }))
};
---

<Layout
  title="Adorable | AI Transformation, Paid Social, Marketing Automation"
  description="Adorable helps growth teams scale with AI transformation, paid social, and marketing automation. Founder: Peter Rosdahl, Stockholm."
  englishPath="/en/"
  lang="en"
>
  <main id="main-content" class="relative overflow-clip">
    <section class="hero-shell border-b border-[color:var(--line)]">
      <div class="hero-orb hero-orb-1" aria-hidden="true"></div>
      <div class="hero-orb hero-orb-2" aria-hidden="true"></div>
      <div class="mx-auto grid w-full max-w-6xl gap-10 px-5 pb-20 pt-18 md:grid-cols-[1.25fr_0.95fr] md:gap-16 md:px-8 md:pb-28 md:pt-24">
        <div>
          <p class="inline-flex items-center rounded-full border border-white/40 bg-white/65 px-3 py-1 text-sm font-semibold uppercase tracking-[0.12em] text-zinc-700 shadow-sm">Strategic Growth Consultancy</p>
          <h1 class="mt-5 text-5xl leading-[1.02] text-zinc-950 sm:text-6xl md:text-7xl">Build the next version of your marketing engine.</h1>
          <p class="mt-6 max-w-xl text-base leading-relaxed text-zinc-700 md:text-lg">
            Adorable partners with leadership teams to modernize demand generation through AI transformation, paid social excellence, and automation systems that actually compound.
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-3">
            <a href="#contact" class="rounded-full bg-zinc-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-zinc-700">Book Intro Call</a>
            <a href="#services" class="rounded-full border border-zinc-300 bg-white/80 px-5 py-3 text-sm font-semibold text-zinc-800 transition hover:border-zinc-500">Explore Services</a>
          </div>
          <ul class="mt-7 flex flex-wrap gap-x-6 gap-y-2 text-base text-zinc-600">
            <li>130+ brands supported</li>
            <li>Founded 2016</li>
            <li>Based in Stockholm</li>
          </ul>
        </div>

        <aside class="rounded-3xl border border-white/50 bg-white/80 p-6 shadow-[0_30px_80px_-40px_rgba(31,24,16,0.55)] backdrop-blur md:p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-zinc-600">What teams hire Adorable for</p>
          <ul class="mt-5 space-y-4 text-base text-zinc-700">
            <li class="rounded-2xl border border-[color:var(--line)] bg-[color:var(--bg-card)] p-4">
              <p class="font-semibold text-zinc-900">AI Transformation</p>
              <p class="mt-1 leading-relaxed">Move from scattered tools to a clear operating model with adoption and governance.</p>
            </li>
            <li class="rounded-2xl border border-[color:var(--line)] bg-[color:var(--bg-card)] p-4">
              <p class="font-semibold text-zinc-900">Paid Social Scale</p>
              <p class="mt-1 leading-relaxed">Turn paid social into a repeatable profit center through creative systems and measurement.</p>
            </li>
            <li class="rounded-2xl border border-[color:var(--line)] bg-[color:var(--bg-card)] p-4">
              <p class="font-semibold text-zinc-900">Automation Foundation</p>
              <p class="mt-1 leading-relaxed">Automate workflows across CRM, content, and campaign ops without adding complexity.</p>
            </li>
          </ul>
        </aside>
      </div>
    </section>

    <section id="services" class="mx-auto w-full max-w-6xl px-5 py-16 md:px-8 md:py-24">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.14em] text-zinc-600">Services</p>
        <h2 class="mt-3 text-4xl leading-tight text-zinc-950 md:text-5xl">Three capabilities. One growth mandate.</h2>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        <article class="rounded-3xl border border-[color:var(--line)] bg-[color:var(--bg-card)] p-6">
          <h3 class="text-2xl text-zinc-900">AI Transformation</h3>
          <p class="mt-3 text-base leading-relaxed text-zinc-700">AI readiness, workflow redesign, enablement, and governance to make AI practical at team level.</p>
          <ul class="mt-5 space-y-2 text-base text-zinc-600">
            <li>Use-case mapping and prioritization</li>
            <li>AI operating model and guardrails</li>
            <li>Leadership and team training</li>
          </ul>
        </article>

        <article class="rounded-3xl border border-[color:var(--line)] bg-[color:var(--bg-card)] p-6">
          <h3 class="text-2xl text-zinc-900">Paid Social</h3>
          <p class="mt-3 text-base leading-relaxed text-zinc-700">End-to-end paid social strategy and execution across Meta, LinkedIn, TikTok, and YouTube.</p>
          <ul class="mt-5 space-y-2 text-base text-zinc-600">
            <li>Account and funnel strategy</li>
            <li>Creative testing systems</li>
            <li>Measurement and scaling playbooks</li>
          </ul>
        </article>

        <article class="rounded-3xl border border-[color:var(--line)] bg-[color:var(--bg-card)] p-6">
          <h3 class="text-2xl text-zinc-900">Marketing Automation</h3>
          <p class="mt-3 text-base leading-relaxed text-zinc-700">Design and implementation of automation flows that reduce manual work and increase conversion velocity.</p>
          <ul class="mt-5 space-y-2 text-base text-zinc-600">
            <li>CRM and lifecycle automation</li>
            <li>Lead scoring and qualification logic</li>
            <li>Reporting and alerting systems</li>
          </ul>
        </article>
      </div>
    </section>

    <section id="case-studies" class="border-y border-[color:var(--line)] bg-[#f5eee5]/65">
      <div class="mx-auto w-full max-w-6xl px-5 py-16 md:px-8 md:py-24">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.14em] text-zinc-600">Case Studies</p>
            <h2 class="mt-3 text-4xl leading-tight text-zinc-950 md:text-5xl">Proof over promises.</h2>
          </div>
          <p class="text-base text-zinc-600">Detailed case studies are being finalized. Preview examples below.</p>
        </div>

        <div class="mt-10 grid gap-5 md:grid-cols-3">
          <article class="rounded-3xl border border-[color:var(--line)] bg-white p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.14em] text-zinc-600">B2B SaaS</p>
            <h3 class="mt-3 text-2xl text-zinc-900">AI-assisted GTM rollout</h3>
            <p class="mt-3 text-base leading-relaxed text-zinc-700">Placeholder: Aligning sales and marketing with AI workflows to cut campaign launch time by 45%.</p>
          </article>
          <article class="rounded-3xl border border-[color:var(--line)] bg-white p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.14em] text-zinc-600">E-commerce</p>
            <h3 class="mt-3 text-2xl text-zinc-900">Paid social scale model</h3>
            <p class="mt-3 text-base leading-relaxed text-zinc-700">Placeholder: Structured creative testing and budget controls that doubled qualified revenue contribution.</p>
          </article>
          <article class="rounded-3xl border border-[color:var(--line)] bg-white p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.14em] text-zinc-600">Education</p>
            <h3 class="mt-3 text-2xl text-zinc-900">Marketing automation rebuild</h3>
            <p class="mt-3 text-base leading-relaxed text-zinc-700">Placeholder: Lifecycle automation redesign improving response speed and reducing manual operations overhead.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="about" class="mx-auto grid w-full max-w-6xl gap-8 px-5 py-16 md:grid-cols-[1.1fr_1fr] md:px-8 md:py-24">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.14em] text-zinc-600">About</p>
        <h2 class="mt-3 text-4xl leading-tight text-zinc-950 md:text-5xl">Peter Rosdahl, founder of Adorable.</h2>
        <p class="mt-6 text-base leading-relaxed text-zinc-700">
          Peter has spent over two decades in digital growth and has advised more than 130 brands since launching Adorable in 2016. Engagements are intentionally focused and senior-led from strategy to execution.
        </p>
        <p class="mt-4 text-base leading-relaxed text-zinc-700">
          The model is simple: identify the highest-leverage bottlenecks, fix the operating system behind them, and transfer capability to the internal team.
        </p>
      </div>
      <div class="rounded-3xl border border-[color:var(--line)] bg-[color:var(--bg-card)] p-6 md:p-8">
        <p class="text-base font-semibold text-zinc-900">Engagement principles</p>
        <ul class="mt-4 space-y-3 text-base leading-relaxed text-zinc-700">
          <li>Small number of clients at any time</li>
          <li>Direct access to senior expertise</li>
          <li>Transparent scope, timeline, and economics</li>
          <li>Execution quality over reporting theater</li>
        </ul>
      </div>
    </section>

    <section class="border-y border-[color:var(--line)] bg-white/80">
      <div class="mx-auto w-full max-w-6xl px-5 py-16 md:px-8 md:py-24">
        <p class="text-sm font-semibold uppercase tracking-[0.14em] text-zinc-600">Testimonials</p>
        <h2 class="mt-3 text-4xl leading-tight text-zinc-950 md:text-5xl">Trusted by teams that need clarity fast.</h2>

        <div class="mt-10 grid gap-5 md:grid-cols-3">
          <figure class="rounded-3xl border border-[color:var(--line)] bg-[color:var(--bg-card)] p-6">
            <blockquote class="text-base leading-relaxed text-zinc-700">"Peter cut through months of internal debate in two workshops and gave us a model we could execute immediately."</blockquote>
            <figcaption class="mt-5 text-base font-medium text-zinc-900">CMO, Nordic SaaS Company</figcaption>
          </figure>
          <figure class="rounded-3xl border border-[color:var(--line)] bg-[color:var(--bg-card)] p-6">
            <blockquote class="text-base leading-relaxed text-zinc-700">"Paid social moved from channel chaos to weekly predictable contribution. The process change was the breakthrough."</blockquote>
            <figcaption class="mt-5 text-base font-medium text-zinc-900">Growth Lead, DTC Brand</figcaption>
          </figure>
          <figure class="rounded-3xl border border-[color:var(--line)] bg-[color:var(--bg-card)] p-6">
            <blockquote class="text-base leading-relaxed text-zinc-700">"The automation work freed up our team and improved conversion speed at the same time. Very practical approach."</blockquote>
            <figcaption class="mt-5 text-base font-medium text-zinc-900">Marketing Director, Education Group</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <section id="blog" class="mx-auto w-full max-w-6xl px-5 py-16 md:px-8 md:py-24">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.14em] text-zinc-600">Insights</p>
          <h2 class="mt-3 text-4xl leading-tight text-zinc-950 md:text-5xl">From the Adorable blog.</h2>
        </div>
        <a href="/artiklar" class="text-base font-semibold text-zinc-900 underline decoration-[color:var(--brand-500)] underline-offset-4">View all articles</a>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {featuredPosts.map((post) => (
          <article class="rounded-3xl border border-[color:var(--line)] bg-[color:var(--bg-card)] p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.14em] text-zinc-600">{post.category}</p>
            <h3 class="mt-3 text-2xl leading-tight text-zinc-900"><a href={post.href} class="hover:text-[color:var(--brand-600)]">{post.title}</a></h3>
            <p class="mt-3 text-base leading-relaxed text-zinc-700">{post.excerpt}</p>
            <a href={post.href} class="mt-5 inline-flex text-base font-semibold text-zinc-900">Read article</a>
          </article>
        ))}
      </div>
    </section>

    <section id="faq" class="border-y border-[color:var(--line)] bg-[#f7f1e8]">
      <div class="mx-auto w-full max-w-4xl px-5 py-16 md:px-8 md:py-24">
        <p class="text-sm font-semibold uppercase tracking-[0.14em] text-zinc-600">FAQ</p>
        <h2 class="mt-3 text-4xl leading-tight text-zinc-950 md:text-5xl">Common questions.</h2>

        <div class="mt-10 space-y-3">
          {faqs.map((item) => (
            <details class="group rounded-2xl border border-[color:var(--line)] bg-white p-5">
              <summary class="cursor-pointer list-none text-base font-semibold text-zinc-900">{item.q}</summary>
              <p class="mt-3 text-base leading-relaxed text-zinc-700">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="mx-auto w-full max-w-4xl px-5 py-16 md:px-8 md:py-24">
      <div class="rounded-3xl border border-[color:var(--line)] bg-[color:var(--bg-card)] p-7 md:p-10">
        <p class="text-sm font-semibold uppercase tracking-[0.14em] text-zinc-600">Contact</p>
        <h2 class="mt-3 text-4xl leading-tight text-zinc-950 md:text-5xl">Start with a focused 30-minute conversation.</h2>
        <p class="mt-4 text-base text-zinc-700">Tell us where your growth engine is stuck. You will get a practical recommendation and a clear next step.</p>

        <form class="mt-8 grid gap-4" action="https://api.web3forms.com/submit" method="POST">
          <input type="hidden" name="access_key" value="658f2386-7125-4653-b0ac-5d725aeab234" />
          <input type="hidden" name="subject" value="New lead from adorable.se" />
          <input type="hidden" name="redirect" value="https://adorable.se/?success=true" />

          <div class="grid gap-4 md:grid-cols-2">
            <label class="text-base font-medium text-zinc-700">
              Name
              <input name="name" type="text" required class="mt-1 w-full rounded-xl border border-zinc-300 bg-white px-4 py-3 text-sm text-zinc-900 outline-none ring-[color:var(--brand-500)] focus:ring-2" />
            </label>
            <label class="text-base font-medium text-zinc-700">
              Work email
              <input name="email" type="email" required class="mt-1 w-full rounded-xl border border-zinc-300 bg-white px-4 py-3 text-sm text-zinc-900 outline-none ring-[color:var(--brand-500)] focus:ring-2" />
            </label>
          </div>

          <label class="text-base font-medium text-zinc-700">
            Company
            <input name="company" type="text" class="mt-1 w-full rounded-xl border border-zinc-300 bg-white px-4 py-3 text-sm text-zinc-900 outline-none ring-[color:var(--brand-500)] focus:ring-2" />
          </label>

          <label class="text-base font-medium text-zinc-700">
            Area
            <select name="interest" required class="mt-1 w-full rounded-xl border border-zinc-300 bg-white px-4 py-3 text-sm text-zinc-900 outline-none ring-[color:var(--brand-500)] focus:ring-2">
              <option value="">Choose one</option>
              <option value="ai-transformation">AI Transformation</option>
              <option value="paid-social">Paid Social</option>
              <option value="marketing-automation">Marketing Automation</option>
              <option value="integrated">Integrated program</option>
            </select>
          </label>

          <label class="text-base font-medium text-zinc-700">
            Message
            <textarea name="message" rows="5" required class="mt-1 w-full rounded-xl border border-zinc-300 bg-white px-4 py-3 text-sm text-zinc-900 outline-none ring-[color:var(--brand-500)] focus:ring-2" placeholder="Share your objective, timeline, and current bottleneck."></textarea>
          </label>

          <div class="flex flex-wrap items-center justify-between gap-4 pt-2">
            <p class="text-sm text-zinc-600">Or email directly: <a href="mailto:peter@adorable.se" class="font-medium text-zinc-900">peter@adorable.se</a></p>
            <button type="submit" class="rounded-full bg-zinc-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-zinc-700">Send Inquiry</button>
          </div>
        </form>
      </div>
    </section>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>

<style>
  .hero-shell {
    position: relative;
    isolation: isolate;
    background: radial-gradient(circle at 20% 20%, rgba(255, 236, 205, 0.8), transparent 55%),
      radial-gradient(circle at 80% 20%, rgba(241, 196, 146, 0.65), transparent 48%),
      linear-gradient(145deg, #fffaf3 0%, #f6ede2 45%, #f4ebe1 100%);
  }

  .hero-orb {
    position: absolute;
    border-radius: 9999px;
    filter: blur(45px);
    opacity: 0.55;
    pointer-events: none;
    animation: drift 18s ease-in-out infinite;
  }

  .hero-orb-1 {
    width: clamp(220px, 34vw, 440px);
    height: clamp(220px, 34vw, 440px);
    top: -90px;
    right: -100px;
    background: linear-gradient(120deg, #f0a867, #dd7f45);
  }

  .hero-orb-2 {
    width: clamp(180px, 25vw, 320px);
    height: clamp(180px, 25vw, 320px);
    bottom: -80px;
    left: -70px;
    background: linear-gradient(120deg, #f8d0a4, #cf8a59);
    animation-delay: -7s;
  }

  @keyframes drift {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(14px, -14px, 0) scale(1.06);
    }
  }
</style>
